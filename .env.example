# --- Email delivery (Resend) ---
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=
# The subscriber list. Create one at https://resend.com/audiences and paste its
# ID here. This is how the service emails everyone (you included). When set, the
# alert is sent as a Broadcast with per-recipient unsubscribe links.
RESEND_AUDIENCE_ID=
# Fallback for local testing only: comma-separated recipients, used when no
# RESEND_AUDIENCE_ID is set. Leave blank in production.
EMAIL_TO=
# Until you verify your own domain in Resend, the shared sender works for testing:
EMAIL_FROM=Be Greedy <onboarding@resend.dev>

# --- Alert behaviour (all optional; sensible defaults shown) ---
# Absolute composite score (0-100) required to send. Higher = rarer/stronger.
ALERT_THRESHOLD=60
# How many individual signals must agree before an alert fires.
MIN_CORROBORATING=2
# Never send more than one alert within this many days.
COOLDOWN_DAYS=7

# --- Flags ---
# DRY_RUN=true   # run the full send path but don't actually deliver
# FORCE=true     # ignore threshold + cooldown (test the wiring)
